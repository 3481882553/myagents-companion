{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "jsx": "react",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["poc/app/src/*"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./poc/app/node_modules/@types"
    ]
  },
  "include": ["poc/app/src/**/*"],
  "exclude": ["node_modules", "poc/app/node_modules"]
}
